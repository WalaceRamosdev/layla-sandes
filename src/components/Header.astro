---
const navItems = [
  { name: 'Home', href: '/' },
  { name: 'Sobre', href: '/sobre' },
  { name: 'Serviços', href: '/servicos' },
  { name: 'Blog', href: '/blog' },
  { name: 'Contato', href: '/contato' },
];
---

<header id="navbar" class="fixed top-0 left-0 w-full z-[80] bg-[#F8F1F2] border-b border-accent/10">
  <nav class="max-w-7xl mx-auto px-6 md:px-12 py-5 flex justify-between items-center relative">
    <!-- Logo -->
    <a href="/" class="text-xl md:text-2xl font-display text-accent tracking-[0.2em] uppercase z-[90]">
      Layla <span class="text-secondary">Sandes</span>
    </a>

    <!-- Desktop Nav -->
    <div class="hidden md:flex items-center space-x-10">
      {navItems.map(item => (
        <a 
          href={item.href} 
          class="text-[10px] uppercase tracking-[0.3em] font-bold text-text-muted hover:text-secondary transition-colors"
        >
          {item.name}
        </a>
      ))}
      <a href="/contato" class="btn-primary px-8 py-2.5 text-[10px]">
        Agendar
      </a>
    </div>

    <!-- Mobile Menu Button (Ultra Visible) -->
    <button id="menu-btn" class="md:hidden text-secondary p-2 z-[100] relative" aria-label="Menu">
      <div id="burger-wrapper" class="transition-all duration-300">
        <svg id="menu-icon" xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
      </div>
      <div id="close-wrapper" class="hidden transition-all duration-300">
        <svg id="close-icon" xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
      </div>
    </button>
  </nav>

  <!-- Mobile Menu Overlay -->
  <div id="mobile-menu" class="hidden md:hidden fixed inset-0 bg-[#F8F1F2] z-[70] flex flex-col pt-32 p-10 h-screen w-full">
    <div class="flex flex-col space-y-6">
      {navItems.map(item => (
        <a 
          href={item.href} 
          class="menu-link text-3xl font-display text-accent uppercase tracking-widest border-b border-accent/10 pb-6 opacity-0 translate-y-6"
        >
          {item.name}
        </a>
      ))}
    </div>
    <div class="pt-12 menu-link opacity-0 translate-y-6">
      <a href="/contato" class="btn-primary w-full py-6 text-center text-sm shadow-2xl tracking-[0.2em]">Agendar Consulta</a>
    </div>
  </div>
</header>

<script>
  import { gsap } from 'gsap';

  function initMenu() {
    const menuBtn = document.getElementById('menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const burgerWrapper = document.getElementById('burger-wrapper');
    const closeWrapper = document.getElementById('close-wrapper');
    const menuLinks = document.querySelectorAll('.menu-link');

    if (!menuBtn || !mobileMenu || !burgerWrapper || !closeWrapper) return;

    let isOpen = false;

    menuBtn.addEventListener('click', () => {
      isOpen = !isOpen;
      
      if (isOpen) {
        // Open
        mobileMenu.classList.remove('hidden');
        gsap.fromTo(mobileMenu, { y: '-100%' }, { y: '0%', duration: 0.5, ease: 'power4.out' });
        
        gsap.to(menuLinks, {
          opacity: 1,
          y: 0,
          stagger: 0.1,
          duration: 0.5,
          ease: 'back.out(1.2)',
          delay: 0.2
        });

        burgerWrapper.classList.add('hidden');
        closeWrapper.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
      } else {
        closeMenu();
      }
    });

    function closeMenu() {
      isOpen = false;
      gsap.to(mobileMenu, { 
        y: '-100%', 
        duration: 0.4, 
        ease: 'power4.in',
        onComplete: () => {
          mobileMenu?.classList.add('hidden');
          gsap.set(menuLinks, { opacity: 0, y: 30 });
        }
      });

      closeWrapper?.classList.add('hidden');
      burgerWrapper?.classList.remove('hidden');
      document.body.style.overflow = 'auto';
    }

    mobileMenu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', closeMenu);
    });
  }

  initMenu();
  document.addEventListener('astro:after-swap', initMenu);
</script>
