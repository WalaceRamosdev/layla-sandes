---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

export function getStaticPaths() {
  return [
    { params: { slug: 'ansiedade' }, props: { 
      title: 'Terapia para Ansiedade Online', 
      h1: 'Lidando com a Ansiedade: Reencontre sua Paz',
      description: 'Tratamento especializado para ansiedade com foco em TCC. Atendimento online com a Dra. Layla Sandes.',
      content: 'A ansiedade pode se manifestar de diversas formas: preocupação excessiva, medo de desagradar e dificuldade em dizer não. Na terapia TCC, trabalhamos para identificar os padrões de pensamento e desenvolver ferramentas práticas para que você recupere o controle da sua vida.',
      forWhom: ['Pessoas que se sentem constantemente sobrecarregadas', 'Quem tem dificuldade em dizer “não” aos outros', 'Quem sofre com o medo constante de desagradar', 'Pessoas em busca de autonomia emocional'],
      benefits: ['Melhor controle sobre pensamentos intrusivos', 'Desenvolvimento de limites saudáveis', 'Recuperação da qualidade de vida', 'Autonomia e segurança emocional'],
      icon: '🍃',
      color: 'bg-green-50'
    }},
    { params: { slug: 'depressao' }, props: { 
      title: 'Terapia para Depressão Online', 
      h1: 'Superando a Depressão: Um Passo de Cada Vez',
      description: 'Suporte especializado para depressão e desânimo via atendimento online com a psicóloga Layla Sandes.',
      content: 'A depressão pode fazer você se sentir desconectado de si mesmo. Meu papel é te acompanhar nessa reestruturação emocional através da TCC, resgatando pequenos prazeres e construindo um novo sentido para o seu dia a dia, tudo de forma prática e acolhedora.',
      forWhom: ['Jovens adultos e adultos com desânimo persistente', 'Idosos em busca de ressignificação', 'Quem sente dificuldade em lidar com a própria rotina', 'Sentimento de vazio ou falta de propósito'],
      benefits: ['Resgate da autoestima e valor próprio', 'Melhoria no nível de energia e disposição', 'Construção de hábitos mais saudáveis', 'Visão mais consciente do presente e futuro'],
      icon: '☀️',
      color: 'bg-blue-50'
    }},
    { params: { slug: 'relacionamentos' }, props: { 
      title: 'Terapia de Relacionamentos Online', 
      h1: 'Relacionamentos e Vínculos Mais Saudáveis',
      description: 'Melhore sua comunicação e aprenda a se posicionar em seus relacionamentos com a terapia TCC online.',
      content: 'Nossas relações definem nossa qualidade de vida. Se você sente dificuldade em se posicionar, medo de ser julgado ou tendência de se colocar em segundo plano, a terapia te ajuda a construir relações onde sua voz também é ouvida e respeitada.',
      forWhom: ['Pessoas com dificuldade em estabelecer limites', 'Ciclos repetitivos de se colocar em segundo plano', 'Dificuldade em expressar necessidades reais', 'Quem busca comunicações mais assertivas'],
      benefits: ['Comunicação mais clara e respeitosa', 'Habilidade de dizer “não” sem culpa', 'Resolução saudável de conflitos', 'Aumento drástico da autoconfiança'],
      icon: '🤝',
      color: 'bg-rose-50'
    }},
    { params: { slug: 'autoconhecimento' }, props: { 
      title: 'Processo de Autoconhecimento Online', 
      h1: 'Autoconhecimento: A Chave para uma Vida Plena',
      description: 'Descubra seus valores e aprenda a lidar com seus padrões emocionais com a psicóloga Layla Sandes.',
      content: 'Através da TCC, investigamos padrões que muitas vezes passam despercebidos, como o excesso de responsabilidade emocional. O objetivo é alinhar suas escolhas aos seus valores reais, promovendo uma vida com muito mais autenticidade e autonomia.',
      forWhom: ['Quem busca entender melhor seus padrões automáticos', 'Pessoas que desejam aumentar sua autoliderança', 'Busca por equilíbrio entre razão e emoção', 'Quem deseja viver de forma mais leve e consciente'],
      benefits: ['Aumento profundo da autopercepção', 'Tomadas de decisão alinhadas aos seus valores', 'Relação mais gentil e leve consigo mesma', 'Clareza mental e autonomia'],
      icon: '✨',
      color: 'bg-amber-50'
    }},
  ];
}

const { title, h1, description, content, forWhom, benefits, icon, color } = Astro.props;
---

<Layout title={title} description={description}>
  <Header />

  <main class="pt-32">
    <section class="section-padding">
      <div class="max-w-7xl mx-auto flex flex-col lg:flex-row gap-16">
        <div class="lg:w-2/3 reveal">
          <a href="/servicos" class="text-accent text-sm font-semibold flex items-center space-x-2 mb-8">
             <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-arrow-left"><path d="m11 17-5-5 5-5"/><path d="M18 12H6"/></svg>
             <span>Voltar para Serviços</span>
          </a>
          <div class={`inline-block text-5xl p-8 border border-accent/20 mb-8`}>{icon}</div>
          <h1 class="text-4xl md:text-6xl mb-8 leading-tight">{h1}</h1>
          <div class="prose prose-lg text-text-muted leading-relaxed mb-12">
            <p>{content}</p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-12 mb-16">
            <div>
              <h3 class="text-xl font-medium mb-6 flex items-center space-x-2 text-accent">
                <span>Para quem é indicado</span>
              </h3>
              <ul class="space-y-4">
                {forWhom.map(item => (
                  <li class="flex items-start space-x-3 text-text-muted">
                    <span class="text-accent">•</span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>
            <div>
              <h3 class="text-xl font-medium mb-6 flex items-center space-x-2 text-accent">
                <span>Benefícios da Terapia</span>
              </h3>
              <ul class="space-y-4">
                {benefits.map(item => (
                  <li class="flex items-start space-x-3 text-text-muted">
                    <span class="text-accent">✓</span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>

        <div class="lg:w-1/3">
          <div class="reveal sticky top-32 p-10 bg-primary border border-accent/20">
            <h3 class="text-2xl mb-6 font-display uppercase tracking-widest text-secondary">Inicie sua mudança</h3>
            <p class="text-sm text-text-muted mb-8 leading-relaxed">Agende uma conversa inicial para avaliarmos como o processo terapêutico (TCC) pode te ajudar a desenvolver mais autonomia.</p>
            <a href="/contato" class="btn-primary w-full text-center mb-6">Agendar Agora</a>
            <p class="text-[9px] text-center text-accent uppercase tracking-[0.2em]">Confidencialidade Garantida</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Other Services Preview -->
    <section class="section-padding bg-white border-t border-secondary/10">
        <div class="max-w-7xl mx-auto">
            <h2 class="text-3xl mb-12">Conheça outras especialidades</h2>
            <div class="flex flex-wrap gap-4">
                <a href="/servicos/ansiedade" class="px-8 py-3 border border-secondary/10 hover:border-secondary hover:text-secondary transition-colors text-xs uppercase tracking-widest">Ansiedade</a>
                <a href="/servicos/depressao" class="px-8 py-3 border border-secondary/10 hover:border-secondary hover:text-secondary transition-colors text-xs uppercase tracking-widest">Depressão</a>
                <a href="/servicos/relacionamentos" class="px-8 py-3 border border-secondary/10 hover:border-secondary hover:text-secondary transition-colors text-xs uppercase tracking-widest">Relacionamentos</a>
                <a href="/servicos/autoconhecimento" class="px-8 py-3 border border-secondary/10 hover:border-secondary hover:text-secondary transition-colors text-xs uppercase tracking-widest">Autoconhecimento</a>
            </div>
        </div>
    </section>
  </main>

  <Footer />
</Layout>
