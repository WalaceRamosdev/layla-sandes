---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { Image } from 'astro:assets';
import heroBg from '../assets/hero_abstract_bg.png';
---

<Layout
	title="Psicologia Clínica"
	description="Dê o primeiro passo para o seu bem-estar. Atendimento especializado em ansiedade, depressão e relacionamentos com a psicóloga Layla Sandes."
>
	<Header />

	<main>
		<!-- Hero Section (KEEPING THE NEW DESIGN) -->
		<section
			id="home"
			class="relative min-h-[90vh] flex items-center pt-20 bg-primary overflow-hidden"
		>
            <!-- Background Abstract Texture -->
            <div class="absolute inset-0 w-full h-full z-0 overflow-hidden pointer-events-none opacity-[0.9]">
                <Image 
                    src={heroBg} 
                    alt="Background Abstrato" 
                    class="w-full h-full object-cover animate-pulse-slow"
                />
                <!-- Gradient Overlay to blend with primary background -->
                <div class="absolute inset-0 bg-gradient-to-b from-primary/5 via-primary/30 to-primary"></div>
            </div>

			<div
				class="max-w-5xl mx-auto px-6 md:px-12 lg:px-24 flex flex-col items-center text-center relative z-10"
			>
				<div class="flex flex-col items-center">
					<h1
						class="text-4xl md:text-6xl lg:text-7xl font-display !text-text-main leading-[1.1] mb-8 max-w-4xl font-bold"
					>
						Você vive cansada(o) de tentar <span
							class="text-secondary italic"><br>Dar conta de tudo?</span>
					</h1>
					<p
						class="text-lg md:text-xl !text-text-main/80 mb-10 max-w-2xl font-semibold"
					>
						Psicoterapia para te ajudar a encontrar leveza e autonomia.
					</p>
					<div class="flex flex-col sm:flex-row gap-6 justify-center">
						<a
							href="#contato"
							class="btn-primary flex items-center justify-center space-x-2 px-10"
						>
							<span>Agendar primeira conversa</span>
							<svg
								xmlns="http://www.w3.org/2000/svg"
								width="18"
								height="18"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
								class="lucide lucide-calendar"
								><rect
									width="18"
									height="18"
									x="3"
									y="4"
									rx="2"
									ry="2"></rect><line
									x1="16"
									x2="16" y1="2"
									y2="6"></line><line
									x1="8"
									x2="8" y1="2"
									y2="6"></line><line
									x1="3"
									x2="21" y1="10"
									y2="10"></line></svg
							>
						</a>
						<a
							href="#sobre"
							class="btn-outline flex items-center justify-center px-10"
						>
							Conhecer Abordagem
						</a>
					</div>
				</div>
			</div>
		</section>

		<!-- Reverting to 2d5c3f3 Structure Below -->
		
		<!-- Pain Points Section -->
		<section class="section-padding bg-white">
			<div class="max-w-7xl mx-auto">
				<div class="text-center mb-20 reveal">
					<h2 class="text-3xl md:text-5xl mb-6">
						Você não está cansado do dia…<br>Está cansado de você mesmo.
					</h2>
					<p class="text-text-muted max-w-2xl mx-auto">
						Às vezes a mente não desliga e o peso de tentar resolver tudo ao redor acaba te deixando em segundo PLANO.
					</p>
				</div>

				<div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-20">
					{
						[
							{
								title: "Mente Inquieta",
								text: "Você pensa demais e não consegue desligar. A mente está sempre um passo à frente, antecipando problemas.",
							},
							{
								title: "Medo de Conflitos",
								text: "Aceita coisas que te incomodam só pra não gerar desconforto, mas vive em conflito por dentro.",
							},
							{
								title: "Prioridade de Outros",
								text: "Resolve a vida de todo mundo… menos a sua. Acredita que precisa dar conta de tudo e isso virou rotina.",
							},
						].map((item) => (
							<div class="p-10 bg-soft-bg rounded-2xl reveal hover:shadow-lg transition-shadow duration-300">
								<h3 class="text-xl font-medium mb-4 text-accent">
									{item.title}
								</h3>
								<p class="text-text-muted leading-relaxed">
									{item.text}
								</p>
							</div>
						))
					}
				</div>

				<!-- Target Audience (Para quem é) -->
				<div id="para-quem" class="bg-primary p-12 md:p-20 rounded-[3rem] reveal">
					<div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
						<div>
							<span class="text-accent uppercase tracking-widest text-xs mb-4 block font-bold">Resonância</span>
							<h2 class="text-3xl md:text-5xl mb-8 leading-tight">A psicoterapia pode ser um caminho se você percebe:</h2>
							<div class="space-y-4">
								{[
									'Ansiedade frequente e pensamentos acelerados',
									'Dificuldade em se priorizar ou estabelecer limites',
									'Medo de decepcionar as pessoas',
									'Relações que geram desgaste emocional',
									'Sensação constante de sobrecarga',
									'Dificuldade em compreender sentimentos próprios'
								].map(item => (
									<div class="flex items-center space-x-3 text-text-muted">
										<span class="w-1.5 h-1.5 bg-accent rounded-full flex-shrink-0"></span>
										<span class="text-lg">{item}</span>
									</div>
								))}
							</div>
						</div>
						<div class="bg-white p-10 rounded-2xl shadow-sm border border-accent/5">
							<h3 class="text-xl font-serif text-secondary mb-4">Não é sobre o que você sente.</h3>
							<p class="text-text-muted leading-relaxed mb-6">
								É sobre há quanto tempo você vem guardando isso. Quando muita coisa fica acumulada e não é falada, a mente não descansa. Os pensamentos voltam, o corpo fica em alerta e tudo começa a pesar mais do que deveria.
							</p>
							<p class="text-lg italic text-accent font-medium leading-relaxed">
								"Mas isso não precisa continuar desse jeito. Vamos entender como seus pensamentos influenciam o que você sente e como você age e, aos poucos, ir mudando isso na prática."
							</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- About Section & Approach -->
		<section id="sobre" class="section-padding bg-soft-bg overflow-hidden">
			<div
				class="max-w-7xl mx-auto flex flex-col lg:flex-row items-center gap-16"
			>
				<div class="lg:w-1/2 reveal">
					<span
						class="text-accent font-medium uppercase tracking-[0.2em] text-[10px] mb-6 block"
						>Sobre Mim</span
					>
					<h2 class="text-4xl md:text-5xl mb-8">
						Layla Sandes - Psicóloga
					</h2>
					<div class="space-y-6">
						<p class="text-lg text-text-muted leading-relaxed">
							Prazer, eu sou Layla Sandes. Psicóloga (CRP: 08/47025), atuo com a Terapia Cognitivo-Comportamental (TCC).
						</p>
						<p class="text-lg text-text-muted">
							Com o tempo, fui percebendo algo simples: quando a mente não está bem, tudo fica mais pesado de sustentar. Por isso, busco oferecer um espaço onde você não precisa saber exatamente o que dizer.
						</p>
					</div>
					
					<div id="about-content" class="h-0 overflow-hidden opacity-0">
						<div class="pt-8 space-y-6">
							<p class="text-lg text-text-muted leading-relaxed">
								Nem estar “organizado(a)” pra começar. Aqui, o processo acontece no seu tempo. A TCC ajuda a entender como pensamentos, emoções e comportamentos se conectam — e como isso impacta diretamente a sua forma de viver.
							</p>
							<p class="text-lg text-text-muted leading-relaxed">
								Além disso, estou em formação e aprofundamento na área de Psicologia Jurídica e Perícia Psicológica, ampliando minha atuação e compreensão dos contextos humanos em diferentes espaços.
							</p>
							<p class="text-lg text-text-muted font-medium italic">
								O cuidado com a sua mente reflete em todas as áreas da sua vida.<br>Vamos começar?
							</p>
						</div>
						
					</div>
					<div class="mt-10 mb-8">
							<a href="#contato" class="btn-primary space-x-2">
								<span>Agendar conversa agora</span>
								<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-calendar"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
							</a>
						</div>

					<button id="btn-read-more" class="text-accent font-bold uppercase tracking-widest text-[10px] flex items-center gap-2 my-8 hover:text-secondary transition-colors group">
						<span id="read-more-text">Ler abordagem completa</span>
						<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-300 group-hover:translate-y-1"><path d="m6 9 6 6 6-6"/></svg>
					</button>
					
					<div class="flex flex-col sm:flex-row gap-6">
						<div class="pt-6 border-t border-accent/10">
							<h4
								class="text-xs uppercase tracking-widest text-accent mb-1 font-bold"
							>
								CRP 08/47025
							</h4>
							<p class="text-[10px] text-text-muted">
								Psicóloga Clínica
							</p>
						</div>
					</div>
				</div>
				<div class="lg:w-1/2 reveal">
					<div class="border border-accent/20 p-2 relative">
						<img
							src="/images/layla/laylasandes-psicologa.webp"
							alt="Layla Sandes"
							class="w-full h-auto"
						/>
					</div>
				</div>
			</div>
		</section>

		<!-- Therapeutic Process Section -->
		<section class="section-padding bg-white overflow-hidden">
			<div class="max-w-7xl mx-auto">
				<div class="text-center mb-20 reveal">
					<span class="text-accent uppercase tracking-widest text-xs mb-4 block font-bold">Metodologia</span>
					<h2 class="text-4xl md:text-5xl mb-6">O Processo Terapêutico</h2>
					<p class="text-text-muted max-w-2xl mx-auto">Construído de forma gradual, respeitando sua singularidade e seu tempo de transformação.</p>
				</div>

				<div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-20">
					{[
						{ 
							step: '01', 
							title: 'Primeira Conversa', 
							text: 'Vamos entender o que você está vivendo, o que te trouxe até aqui e o que você espera da terapia.' 
						},
						{ 
							step: '02', 
							title: 'Identificação', 
							text: 'Trabalhamos na identificação de padrões e organização dos pensamentos que hoje geram desconforto.' 
						},
						{ 
							step: '03', 
							title: 'Construção', 
							text: 'Construímos formas mais claras e saudáveis de lidar com o que você está passando no dia a dia.' 
						}
					].map(item => (
						<div class="relative p-10 border border-accent/10 rounded-3xl reveal hover:bg-primary transition-colors">
							<span class="text-6xl font-display text-accent/5 absolute top-4 right-8">{item.step}</span>
							<h3 class="text-2xl mb-4 text-secondary">{item.title}</h3>
							<p class="text-text-muted leading-relaxed text-sm">{item.text}</p>
						</div>
					))}
				</div>

				<!-- Details / Operation -->
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center bg-primary p-12 md:p-20 rounded-[3rem] reveal">
					<div>
						<h2 class="text-3xl md:text-4xl mb-8 leading-tight">Como ocorrem as sessões?</h2>
						<div class="space-y-8">
							<div class="flex items-start space-x-4">
								<div class="w-10 h-10 bg-white rounded-full flex items-center justify-center flex-shrink-0 text-accent shadow-sm">
									<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-video"><path d="m16 13 5.223 3.482a.5.5 0 0 0 .777-.416V7.934a.5.5 0 0 0-.777-.416L16 11"/><rect width="14" height="12" x="2" y="6" rx="2"/></svg>
								</div>
								<div>
									<h4 class="text-accent font-bold uppercase tracking-widest text-[10px] mb-1">Formato 100% Online</h4>
									<p class="text-sm text-text-muted">Realizado via Google Meet. Você receberá um link seguro antes de cada encontro direto no seu WhatsApp.</p>
								</div>
							</div>
							<div class="flex items-start space-x-4">
								<div class="w-10 h-10 bg-white rounded-full flex items-center justify-center flex-shrink-0 text-accent shadow-sm">
									<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-clock-3"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16.5 12"/></svg>
								</div>
								<div>
									<h4 class="text-accent font-bold uppercase tracking-widest text-[10px] mb-1">Duração e Frequência</h4>
									<p class="text-sm text-text-muted">Sessões de aprox. 50 min. Frequência geralmente semanal, podendo variar conforme o processo.</p>
								</div>
							</div>
						</div>
					</div>
					<div class="relative flex items-center justify-center bg-primary/20 rounded-3xl min-h-[400px] border border-accent/10 overflow-hidden group">
                        <!-- Abstract Connection Artifact -->
                        <div class="relative w-64 h-64 flex items-center justify-center">
                            <!-- Pulsing Aura -->
                            <div class="absolute inset-0 bg-accent/5 rounded-full animate-ping opacity-20"></div>
                            <div class="absolute inset-4 border border-accent/10 rounded-full animate-pulse-slow opacity-40"></div>
                            <div class="absolute inset-12 border border-secondary/20 rounded-full animate-pulse opacity-30 [animation-delay:0.5s]"></div>
                            
                            <!-- Central Connection Symbol -->
                            <svg viewBox="0 0 100 100" class="w-32 h-32 relative z-10 transition-transform duration-700 group-hover:scale-110">
                                <defs>
                                    <linearGradient id="connGradient" x1="0%" y1="0%" x2="100%" y2="0%">
                                        <stop offset="0%" style="stop-color:var(--color-secondary);stop-opacity:1" />
                                        <stop offset="100%" style="stop-color:var(--color-accent);stop-opacity:1" />
                                    </linearGradient>
                                </defs>
                                <!-- Infinity Flow -->
                                <path 
                                    d="M30,50 C30,30 50,30 50,50 C50,70 70,70 70,50" 
                                    fill="none" 
                                    stroke="url(#connGradient)" 
                                    stroke-width="1.5" 
                                    stroke-linecap="round"
                                    class="opacity-80"
                                />
                                <circle cx="30" cy="50" r="3" fill="currentColor" class="text-secondary animate-pulse" />
                                <circle cx="70" cy="50" r="3" fill="currentColor" class="text-accent animate-pulse [animation-delay:0.7s]" />
                                <!-- Core Spark -->
                                <circle cx="50" cy="50" r="1.5" fill="currentColor" class="text-accent animate-ping" />
                            </svg>
                        </div>

						<div class="absolute -bottom-6 -right-6 bg-accent p-8 text-white rounded-2xl hidden md:block">
							<p class="text-xs uppercase tracking-widest font-bold">Sigilo e Ética</p>
							<p class="text-[9px] opacity-80 mt-1">Ambiente seguro e reservado.</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Services Section -->
		<section id="servicos" class="section-padding bg-soft-bg">
			<div class="max-w-7xl mx-auto text-center mb-16 reveal">
				<span
					class="text-accent uppercase tracking-widest text-sm mb-4 block"
					>Especialidades</span
				>
				<h2 class="text-4xl md:text-5xl mb-6">Como posso te ajudar?</h2>
				<p class="text-text-muted">
					Abordagens personalizadas para as suas necessidades
					específicas.
				</p>
			</div>

			<div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
				{[
					{
						title: "Psicoterapia Online",
						icon: "🌿",
						text: "Trabalho contínuo focado em ansiedade, depression, relacionamentos e autoconhecimento. Frequência semanal para aprofundamento emocional.",
						color: "bg-white",
						highlight: true
					},
					{
						title: "Plantão Psicológico",
						icon: "🕰️",
						text: "Atendimento pontual em sessão única para momentos de sobrecarga, decisões difíceis ou conflitos imediatos. Um espaço de escuta agora.",
						color: "bg-white",
						highlight: false
					},
					{
						title: "Orientação e Suporte",
						icon: "🤝",
						text: "Auxílio estratégico para momentos de transição, dificuldades profissionais ou desenvolvimento de habilidades interpessoais específicas.",
						color: "bg-white",
						highlight: false
					}
				].map((servico) => (
					<div class={`reveal p-10 rounded-[2.5rem] ${servico.color} border border-accent/10 hover:border-secondary/20 transition-all duration-300 shadow-sm hover:shadow-xl`}>
						<div class="text-5xl mb-6">{servico.icon}</div>
						<h3 class="text-2xl font-serif mb-4 text-secondary">{servico.title}</h3>
						<p class="text-sm text-text-muted mb-8 leading-relaxed">{servico.text}</p>
						{servico.title === 'Plantão Psicológico' && (
							<p class="text-[10px] text-accent font-bold mb-4 uppercase tracking-widest">Duração aproximada: 50 min</p>
						)}
						<a href="#contato" class="text-xs font-bold text-accent uppercase tracking-widest hover:text-secondary border-b border-accent/20 pb-1">Ver disponibilidade</a>
					</div>
				))}
			</div>
			
			<div class="max-w-4xl mx-auto mt-20 p-10 bg-secondary/5 rounded-3xl border border-secondary/10 reveal text-center">
				<h4 class="text-secondary font-display text-2xl mb-4 italic">Sobre o Plantão Psicológico</h4>
				<p class="text-sm text-text-muted leading-relaxed">
					"O plantão não substitui a terapia contínua, mas é um primeiro passo vital em momentos de necessidade urgente, permitindo compreender melhor a experiência e reorganizar possibilidades."
				</p>
			</div>
		</section>

		<!-- Steps to Start Section -->
		<section class="section-padding bg-white">
			<div class="max-w-7xl mx-auto">
				<div class="text-center mb-20 reveal">
					<span class="text-accent uppercase tracking-widest text-xs mb-4 block font-bold">Simplicidade</span>
					<h2 class="text-4xl md:text-5xl mb-6">Como iniciar seu atendimento?</h2>
					<p class="text-text-muted">Siga estes quatro passos para começar sua jornada.</p>
				</div>

				<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
					{[
						{ num: '1', title: 'Contato', text: 'Você entra em contato comigo via WhatsApp.' },
						{ num: '2', title: 'Conversa', text: 'Alinhamos o funcionamento e os horários disponíveis.' },
						{ num: '3', title: 'Agendamento', text: 'Marcamos sua primeira sessão para o melhor momento.' },
						{ num: '4', title: 'Início', text: 'Damos início ao seu processo terapêutico.' }
					].map(step => (
						<div class="flex flex-col items-center text-center reveal group">
							<div class="w-16 h-16 bg-primary rounded-full flex items-center justify-center text-accent text-2xl font-display mb-6 group-hover:bg-secondary group-hover:text-white transition-all duration-500 shadow-sm">
								{step.num}
							</div>
							<h3 class="text-xl mb-3 text-secondary">{step.title}</h3>
							<p class="text-sm text-text-muted italic">{step.text}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- Contact Section -->
		<section id="contato" class="section-padding bg-primary">
			<div
				class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-20"
			>
				<div class="reveal">
					<span
						class="text-accent uppercase tracking-[0.2em] text-[10px] mb-6 block"
						>Agendamento</span
					>
					<h2 class="text-4xl md:text-6xl mb-8 leading-tight">
						Escolha investir <br class="hidden md:block" /> na sua <span
							class="italic text-secondary">saúde mental.</span>
					</h2>
					<p class="text-lg text-text-muted mb-12">
						O primeiro passo é the most important, e você não precisa
						caminhar sozinha. Vamos conversar? Atendimento 100%
						online.
					</p>

					<div class="space-y-8">
						<div class="flex items-center space-x-4">
							<div
								class="w-12 h-12 bg-secondary/10 flex items-center justify-center text-secondary rounded-full"
							>
								<svg
									xmlns="http://www.w3.org/2000/svg"
									width="20"
									height="20"
									viewBox="0 0 24 24"
									fill="none"
									stroke="currentColor"
									stroke-width="2"
									stroke-linecap="round"
									stroke-linejoin="round"
									class="lucide lucide-message-square"
									><path
										d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"
									></path></svg
								>
							</div>
							<div>
								<h4
									class="text-xs uppercase tracking-widest text-accent font-bold"
								>
									WhatsApp
								</h4>
								<a
									href="https://wa.me/5544991581606"
									target="_blank"
									class="text-sm text-text-muted hover:text-secondary transition-colors"
									>(44) 99158-1606</a
								>
							</div>
						</div>
						<div class="flex items-center space-x-4">
							<div
