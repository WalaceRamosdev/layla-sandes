<script>
	import { gsap } from 'gsap';

	function initReadMore() {
		const btn = document.getElementById('btn-read-more');
		const content = document.getElementById('about-content');
		const text = document.getElementById('read-more-text');
		const icon = btn?.querySelector('svg');

		if (!btn || !content || !text || !icon) return;

		let isOpen = false;

		btn.addEventListener('click', () => {
			isOpen = !isOpen;

			if (isOpen) {
				gsap.to(content, {
					height: 'auto',
					opacity: 1,
					duration: 0.8,
					ease: 'power3.out'
				});
				text.innerText = 'Ver menos';
				gsap.to(icon, { rotate: 180, duration: 0.3 });
			} else {
				gsap.to(content, {
					height: 0,
					opacity: 0,
					duration: 0.6,
					ease: 'power3.in'
				});
				text.innerText = 'Ler trajetória completa';
				gsap.to(icon, { rotate: 0, duration: 0.3 });
			}
		});
	}

	function initContactForm() {
		const form = document.getElementById('form-contato') as HTMLFormElement;
		if (!form) return;

		form.addEventListener('submit', (e) => {
			e.preventDefault();
			
			const nomeEl = document.getElementById('contato-nome') as HTMLInputElement | null;
			const whatsappEl = document.getElementById('contato-whatsapp') as HTMLInputElement | null;
			const mensagemEl = document.getElementById('contato-mensagem') as HTMLTextAreaElement | null;

			if (!nomeEl || !whatsappEl || !mensagemEl) return;

			const nome = nomeEl.value;
			const whatsapp = whatsappEl.value;
			const mensagem = mensagemEl.value;
			
			const numeroWhatsApp = '5544991581606';
			const textoBase = `Olá Layla, meu nome é ${nome}. \n\nTenho interesse em agendar uma conversa. \n\n*WhatsApp:* ${whatsapp} \n*Mensagem:* ${mensagem}`;
			
			const url = `https://wa.me/${numeroWhatsApp}?text=${encodeURIComponent(textoBase)}`;
			
			window.open(url, '_blank');
		});
	}

	initReadMore();
	initContactForm();
	document.addEventListener('astro:after-swap', () => {
		initReadMore();
		initContactForm();
	});
</script>

<style>
    .animate-pulse-slow {
        animation: pulse-slow 15s infinite ease-in-out;
    }
    @keyframes pulse-slow {
        0%, 100% { opacity: 0.6; transform: scale(1); }
        50% { opacity: 0.9; transform: scale(1.05); }
    }
</style>
