---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { Image } from 'astro:assets';
import heroBg from '../assets/hero_abstract_bg.png';
---

<Layout
	title="Psicologia Clínica"
	description="Dê o primeiro passo para o seu bem-estar. Atendimento especializado em ansiedade, depressão e relacionamentos com a psicóloga Layla Sandes."
>
	<Header />

	<main>
		<!-- Hero Section -->
		<section
			id="home"
			class="relative min-h-[90vh] flex items-center pt-20 bg-primary overflow-hidden"
		>
            <!-- Background Abstract Texture -->
            <div class="absolute inset-0 w-full h-full z-0 overflow-hidden pointer-events-none opacity-[0.9]">
                <Image 
                    src={heroBg} 
                    alt="Background Abstrato" 
                    class="w-full h-full object-cover animate-pulse-slow"
                />
                <!-- Gradient Overlay to blend with primary background -->
                <div class="absolute inset-0 bg-gradient-to-b from-primary/5 via-primary/30 to-primary"></div>
            </div>

			<div
				class="max-w-5xl mx-auto px-6 md:px-12 lg:px-24 flex flex-col items-center text-center relative z-10"
			>
				<div class="flex flex-col items-center">
					<h1
						class="text-4xl md:text-6xl lg:text-7xl font-display !text-text-main leading-[1.1] mb-8 max-w-4xl font-bold"
					>
						Nem sempre é fácil compreender aquilo que <span
							class="text-secondary italic">Sentimos.</span>
					</h1>
					<p
						class="text-lg md:text-xl !text-text-main/80 mb-10 max-w-2xl font-semibold"
					>
						Psicoterapia com base científica e escuta acolhedora.
					</p>
					<div class="flex flex-col sm:flex-row gap-6 justify-center">
						<a
							href="#contato"
							class="btn-primary flex items-center justify-center space-x-2 px-10"
						>
							<span>Agendar Consulta</span>
							<svg
								xmlns="http://www.w3.org/2000/svg"
								width="18"
								height="18"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
								class="lucide lucide-calendar"
								><rect
									width="18"
									height="18"
									x="3"
									y="4"
									rx="2"
									ry="2"></rect><line
									x1="16"
									x2="16"
									y1="2"
									y2="6"></line><line
									x1="8"
									x2="8"
									y1="2"
									y2="6"></line><line
									x1="3"
									x2="21"
									y1="10"
									y2="10"></line></svg
							>
						</a>
						<a
							href="#sobre"
							class="btn-outline flex items-center justify-center px-10"
						>
							Conhecer Abordagem
						</a>
					</div>
				</div>
			</div>
		</section>

		<!-- Pain Points Section -->
		<section class="section-padding bg-white">
			<div class="max-w-7xl mx-auto">
				<div class="text-center mb-20 reveal">
					<h2 class="text-3xl md:text-5xl mb-6">
						Como você tem se sentido ultimamente?
					</h2>
					<p class="text-text-muted max-w-2xl mx-auto">
						Muitas vezes o peso do cotidiano e as feridas emocionais
						nos impedem de enxergar novos caminhos.
					</p>
				</div>

				<div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-20">
					{
						[
							{
								title: "Medo de Desagradar",
								text: "Dificuldade em dizer “não” e a tendência constante de se colocar em segundo plano para priorizar os outros.",
							},
							{
								title: "Ansiedade e Padrões",
								text: "Sentimento de urgência e um olhar atento para padrões de comportamento que hoje passam despercebidos.",
							},
							{
								title: "Falta de Autonomia",
								text: "Sensação de excesso de responsabilidade emocional e dificuldade em se posicionar de forma autêntica.",
							},
						].map((item) => (
							<div class="p-10 bg-soft-bg rounded-2xl reveal hover:shadow-lg transition-shadow duration-300">
								<h3 class="text-xl font-medium mb-4 text-accent">
									{item.title}
								</h3>
								<p class="text-text-muted leading-relaxed">
									{item.text}
								</p>
							</div>
						))
					}
				</div>

				<!-- Target Audience (Para quem é) -->
				<div id="para-quem" class="bg-primary p-12 md:p-20 rounded-[3rem] reveal">
					<div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
						<div>
							<span class="text-accent uppercase tracking-widest text-xs mb-4 block font-bold">Resonância</span>
							<h2 class="text-3xl md:text-5xl mb-8 leading-tight">A psicoterapia pode ser um caminho se você percebe:</h2>
							<div class="space-y-4">
								{[
									'Ansiedade frequente e pensamentos acelerados',
									'Dificuldade em se priorizar ou estabelecer limites',
									'Medo de decepcionar as pessoas',
									'Relações que geram desgaste emocional',
									'Sensação de cansaço ou sobrecarga'
								].map((text) => (
									<div class="flex items-center space-x-3">
										<div class="w-1.5 h-1.5 bg-accent rounded-full"></div>
										<p class="text-text-muted">{text}</p>
									</div>
								))}
							</div>
						</div>
						<div class="relative group">
							<div class="absolute -inset-4 bg-accent/10 rounded-[3rem] blur-2xl group-hover:bg-accent/20 transition-all duration-700"></div>
							<img 
								src="/images/layla/laylasandes-atendimento-online.webp" 
								alt="Psicoterapia online" 
								class="relative rounded-[2.5rem] shadow-2xl w-full h-[500px] object-cover"
							/>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- About Section -->
		<section id="sobre" class="section-padding bg-white overflow-hidden">
			<div class="max-w-7xl mx-auto">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
					<div class="relative reveal">
						<div class="absolute -top-10 -left-10 w-40 h-40 bg-secondary/5 rounded-full blur-3xl"></div>
						<img 
							src="/images/layla/laylasandes-psicologa-tp.webp" 
							alt="Psicóloga Layla Sandes" 
							class="relative z-10 w-full rounded-2xl shadow-xl"
						/>
					</div>
					<div class="reveal">
						<span class="text-secondary uppercase tracking-[0.2em] text-xs font-semibold mb-4 block italic">Cuidar de si é o primeiro passo</span>
						<h2 class="text-4xl md:text-5xl mb-8">Olá, sou Layla Sandes</h2>
						<div class="space-y-6 text-text-muted leading-relaxed">
							<p> Sou psicóloga clínica (CRP 08/47025) com pós-graduanda em Terapia Cognitivo-comportamental (TCC) e com capacitação em psicopatologia clínica.</p>
							<p>Meu foco é auxiliar jovens adultos, adultos e idosos no desenvolvimento da autonomia emocional, oferecendo ferramentas para lidar com a ansiedade e padrões de comportamento que geram sofrimento.</p>
							<p>Através de uma escuta qualificada e ética, construímos juntos um espaço seguro para que você possa se posicionar de forma autêntica e recuperar o protagonismo da sua própria vida.</p>
						</div>
						
						<!-- Read More Section -->
						<div id="read-more-content" class="hidden overflow-hidden transition-all duration-500 ease-in-out">
							<div class="pt-6 space-y-6 text-text-muted leading-relaxed">
								<p>Minha atuação é pautada pelo compromisso com a ciência e pelo respeito à individualidade de cada paciente. Acredito que a psicoterapia é um investimento contínuo em liberdade e bem-estar.</p>
                                <p>No processo terapêutico, trabalhamos na identificação e reestruturação de pensamentos disfuncionais, promovendo mudanças significativas na forma como você se relaciona consigo mesmo e com o mundo ao seu redor.</p>
							</div>
						</div>
						
						<button id="read-more-btn" class="mt-10 flex items-center space-x-2 text-secondary font-semibold hover:tracking-wider transition-all duration-300">
							<span id="read-more-text">Ler trajetória completa</span>
							<svg id="read-more-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-300"><path d="m6 9 6 6 6-6"/></svg>
						</button>
					</div>
				</div>
			</div>
		</section>

		<!-- Services Section -->
		<section id="servicos" class="section-padding bg-primary relative overflow-hidden">
			<div class="absolute top-0 right-0 w-96 h-96 bg-accent/5 rounded-full blur-3xl -mr-48 -mt-48"></div>
			<div class="max-w-7xl mx-auto relative z-10">
				<div class="text-center mb-20 reveal">
					<h2 class="text-4xl md:text-5xl mb-6">Como posso te ajudar</h2>
					<p class="text-text-muted max-w-2xl mx-auto italic">O processo terapêutico é focado em ferramentas práticas para o seu dia a dia.</p>
				</div>
				
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-stretch">
					<div class="bg-white p-12 rounded-[2.5rem] shadow-sm hover:shadow-xl transition-all duration-500 hover:-translate-y-2 reveal flex flex-col items-center text-center">
						<div class="w-20 h-20 bg-primary rounded-full flex items-center justify-center text-secondary mb-8 shadow-inner">
							<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
						</div>
						<h3 class="text-2xl mb-6 text-accent">Psicoterapia Individual</h3>
						<p class="text-text-muted leading-relaxed mb-8">Atendimento personalizado para jovens e adultos, focado em autoconhecimento e resolução de demandas emocionais específicas através da TCC.</p>
						<ul class="space-y-4 text-left w-full max-w-sm mx-auto mb-10">
							<li class="flex items-start space-x-3">
								<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-secondary mt-1 shrink-0"><path d="M20 6 9 17l-5-5"/></svg>
								<span class="text-text-muted italic">Manejo de ansiedade e estresse</span>
							</li>
							<li class="flex items-start space-x-3">
								<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-secondary mt-1 shrink-0"><path d="M20 6 9 17l-5-5"/></svg>
								<span class="text-text-muted italic">Fortalecimento da autoestima</span>
							</li>
						</ul>
						<a href="#contato" class="text-secondary font-bold border-b-2 border-secondary/20 pb-1 hover:border-secondary transition-all">Saber mais detalhes</a>
					</div>

					<div class="bg-white p-12 rounded-[2.5rem] shadow-sm hover:shadow-xl transition-all duration-500 hover:-translate-y-2 reveal flex flex-col items-center text-center">
						<div class="w-20 h-20 bg-primary rounded-full flex items-center justify-center text-secondary mb-8 shadow-inner">
							<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" x2="22" y1="12" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
						</div>
						<h3 class="text-2xl mb-6 text-accent">Atendimento Online</h3>
						<p class="text-text-muted leading-relaxed mb-8">Sessões realizadas via vídeo com total sigilo e conveniência, permitindo que você cuide da sua saúde mental de onde estiver.</p>
						<ul class="space-y-4 text-left w-full max-w-sm mx-auto mb-10">
							<li class="flex items-start space-x-3">
								<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-secondary mt-1 shrink-0"><path d="M20 6 9 17l-5-5"/></svg>
								<span class="text-text-muted italic">Plataformas seguras e sigilosas</span>
							</li>
							<li class="flex items-start space-x-3">
								<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-secondary mt-1 shrink-0"><path d="M20 6 9 17l-5-5"/></svg>
								<span class="text-text-muted italic">Flexibilidade de horários</span>
							</li>
						</ul>
						<a href="#contato" class="text-secondary font-bold border-b-2 border-secondary/20 pb-1 hover:border-secondary transition-all">Saber mais detalhes</a>
					</div>
				</div>
			</div>
		</section>

		<!-- Contact Section -->
		<section id="contato" class="section-padding bg-white relative">
			<div class="max-w-7xl mx-auto">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
					<div class="reveal">
						<h2 class="text-4xl md:text-5xl mb-8 leading-tight">Vamos iniciar sua jornada de transformação?</h2>
						<p class="text-lg text-text-muted mb-12">Se você sente que é o momento de priorizar sua saúde emocional, clique no botão para enviar uma mensagem via WhatsApp ou preencha o formulário.</p>
						
						<div class="flex flex-col space-y-6">
							<div class="flex items-center space-x-4">
								<div class="w-12 h-12 bg-primary rounded-full flex items-center justify-center text-secondary">
									<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
								</div>
								<div>
									<p class="text-xs uppercase tracking-widest text-accent font-bold">WhatsApp</p>
									<p class="text-lg font-medium text-text-main">(44) 99158-1606</p>
								</div>
							</div>
							
							<div class="flex items-center space-x-4">
								<div class="w-12 h-12 bg-primary rounded-full flex items-center justify-center text-secondary">
									<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" x2="22" y1="12" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
								</div>
								<div>
                                    <p class="text-xs uppercase tracking-widest text-accent font-bold">Atendimento</p>
                                    <p class="text-lg font-medium text-text-main">Online para todo o Brasil</p>
                                </div>
							</div>
						</div>
					</div>

					<div class="bg-primary p-10 md:p-16 rounded-[3rem] shadow-xl reveal">
						<form id="whatsapp-form" class="space-y-6">
							<div>
								<label for="form-name" class="block text-sm font-semibold mb-2">Nome Completo</label>
								<input 
									type="text" 
									id="form-name" 
									placeholder="Seu nome"
									required
									class="w-full bg-white border-0 rounded-2xl p-4 focus:ring-2 focus:ring-secondary/20 transition-all outline-none"
								/>
							</div>
							<div>
								<label for="form-phone" class="block text-sm font-semibold mb-2">Seu WhatsApp</label>
								<input 
									type="tel" 
									id="form-phone" 
									placeholder="(00) 00000-0000"
									required
									class="w-full bg-white border-0 rounded-2xl p-4 focus:ring-2 focus:ring-secondary/20 transition-all outline-none"
								/>
							</div>
							<div>
								<label for="form-message" class="block text-sm font-semibold mb-2">Mensagem</label>
								<textarea 
									id="form-message" 
									rows="4" 
									placeholder="Como posso te ajudar?"
									required
									class="w-full bg-white border-0 rounded-2xl p-4 focus:ring-2 focus:ring-secondary/20 transition-all outline-none resize-none"
								></textarea>
							</div>
							<button type="submit" class="btn-primary w-full py-5 text-sm rounded-2xl shadow-lg hover:shadow-secondary/20 active:scale-95">ENVIAR PEDIDO DE CONTATO</button>
						</form>
					</div>
				</div>
			</div>
		</section>
	</main>

	<Footer />

</Layout>

<script>
	import gsap from 'gsap';

	function initReadMore() {
		const btn = document.getElementById('read-more-btn');
		const content = document.getElementById('read-more-content');
		const text = document.getElementById('read-more-text');
		const icon = document.getElementById('read-more-icon');
		
		if (!btn || !content || !text || !icon) return;

		let isOpen = false;

		btn.addEventListener('click', () => {
			isOpen = !isOpen;
			
			if (isOpen) {
				content.classList.remove('hidden');
				const height = content.scrollHeight;
				gsap.fromTo(content, { height: 0, opacity: 0 }, { height: height, opacity: 1, duration: 0.8, ease: 'power3.out' });
				text.innerText = 'Ver menos sobre mim';
				gsap.to(icon, { rotate: 180, duration: 0.3 });
			} else {
				gsap.to(content, { 
					height: 0, 
					opacity: 0, 
					duration: 0.6, 
					ease: 'power3.in',
					onComplete: () => content.classList.add('hidden')
				});
				text.innerText = 'Ler trajetória completa';
				gsap.to(icon, { rotate: 0, duration: 0.3 });
			}
		});
	}

	initReadMore();

	function initWhatsappForm() {
		const form = document.getElementById('whatsapp-form') as HTMLFormElement;
		if (!form) return;

		form.addEventListener('submit', (e) => {
			e.preventDefault();
			
			const name = (document.getElementById('form-name') as HTMLInputElement).value;
			const phone = (document.getElementById('form-phone') as HTMLInputElement).value;
			const message = (document.getElementById('form-message') as HTMLTextAreaElement).value;

			const whatsappNumber = '5544991581606';
			const text = encodeURIComponent(`Olá Layla, meu nome é ${name}.\nMeu WhatsApp é: ${phone}\n\n${message}`);
			
			window.open(`https://wa.me/${whatsappNumber}?text=${text}`, '_blank');
		});
	}

	initWhatsappForm();

	document.addEventListener('astro:after-swap', () => {
		initReadMore();
		initWhatsappForm();
	});
</script>

<style>
	@keyframes float {
		0%, 100% { transform: translate(0, 0); }
		50% { transform: translate(40px, -40px); }
	}
	@keyframes float-delayed {
		0%, 100% { transform: translate(0, 0); }
		50% { transform: translate(-40px, 40px); }
	}
	.animate-float {
		animation: float 22s infinite ease-in-out;
	}
	.animate-float-delayed {
		animation: float-delayed 28s infinite ease-in-out;
	}
    
    .mesh-gradient {
        background-color: #F8F1F2;
        background-image: 
            radial-gradient(at 0% 0%, rgba(138, 30, 34, 0.25) 0px, transparent 50%),
            radial-gradient(at 50% 0%, rgba(200, 154, 75, 0.2) 0px, transparent 50%),
            radial-gradient(at 100% 0%, rgba(138, 30, 34, 0.15) 0px, transparent 50%),
            radial-gradient(at 0% 50%, rgba(200, 154, 75, 0.2) 0px, transparent 50%),
            radial-gradient(at 100% 50%, rgba(138, 30, 34, 0.25) 0px, transparent 50%),
            radial-gradient(at 0% 100%, rgba(138, 30, 34, 0.15) 0px, transparent 50%),
            radial-gradient(at 50% 100%, rgba(200, 154, 75, 0.25) 0px, transparent 50%),
            radial-gradient(at 100% 100%, rgba(138, 30, 34, 0.15) 0px, transparent 50%);
        background-size: 150% 150%;
        animation: mesh-flow 12s infinite ease-in-out;
    }

    @keyframes mesh-flow {
        0%, 100% { background-position: 0% 50%; }
        50% { background-position: 100% 50%; }
    }
    .animate-pulse-slow {
        animation: pulse-slow 15s infinite ease-in-out;
    }
    @keyframes pulse-slow {
        0%, 100% { opacity: 0.6; transform: scale(1); }
        50% { opacity: 0.9; transform: scale(1.05); }
    }
</style>
