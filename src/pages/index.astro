---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

// Use the generated image path (it will be copied to public by the user or I can mock the path)
// Actually, I should use a path that will work in the final project. 
// I'll suggest the user to put it in /public/images/hero.png
const heroImage = "/images/layla/layla-sandes-hero.png"; 
---

<Layout 
	title="Psicologia Clínica" 
	description="Dê o primeiro passo para o seu bem-estar. Atendimento especializado em ansiedade, depressão e relacionamentos com a psicóloga Layla Sandes."
>
	<Header />
	
	<main>
		<!-- Hero Section -->
		<section class="relative min-h-screen flex items-center pt-20 bg-primary">
			<div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-24 flex flex-col-reverse lg:grid lg:grid-cols-2 gap-12 items-center">
				<div class="reveal">
				
					<h1 class="text-5xl md:text-8xl font-display text-accent leading-tight mb-8">
						Mais leveza  <span class="text-secondary italic"><br>com Você.</span>
					</h1>
					<p class="text-lg text-text-muted mb-10 max-w-lg">
						Psicóloga especialista em TCC, focada em ajudar você a superar a ansiedade, o medo de desagradar e a desenvolver sua autonomia emocional.
					</p>
					<div class="flex flex-col sm:flex-row gap-4">
						<a href="/contato" class="btn-primary flex items-center justify-center space-x-2">
							<span>Agendar Consulta</span>
							<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-calendar"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
						</a>
						<a href="/sobre" class="btn-outline flex items-center justify-center">
							Conhecer Abordagem
						</a>
					</div>
				</div>
				<div class="reveal relative">
					<div class="border border-accent/20 p-2 relative z-10 shadow-2xl">
						<img 
							src={heroImage} 
							alt="Layla Sandes - Psicóloga" 
							class="w-full h-auto"
						/>
					</div>
					<!-- Decoration -->
					<div class="absolute -bottom-10 -left-10 w-40 h-40 bg-accent/10 rounded-full blur-3xl"></div>
					<div class="absolute -top-10 -right-10 w-60 h-60 bg-secondary/5 rounded-full blur-3xl"></div>
				</div>
			</div>
		</section>

		<!-- Pain Points Section -->
		<section class="section-padding bg-white">
			<div class="max-w-7xl mx-auto">
				<div class="text-center mb-20 reveal">
					<h2 class="text-3xl md:text-5xl mb-6">Como você tem se sentido ultimamente?</h2>
					<p class="text-text-muted max-w-2xl mx-auto">
						Muitas vezes o peso do cotidiano e as feridas emocionais nos impedem de enxergar novos caminhos.
					</p>
				</div>
				
				<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
					{[
						{ title: 'Medo de Desagradar', text: 'Dificuldade em dizer “não” e a tendência constante de se colocar em segundo plano para priorizar os outros.' },
						{ title: 'Ansiedade e Padrões', text: 'Sentimento de urgência e um olhar atento para padrões de comportamento que hoje passam despercebidos.' },
						{ title: 'Falta de Autonomia', text: 'Sensação de excesso de responsabilidade emocional e dificuldade em se posicionar de forma autêntica.' }
					].map(item => (
						<div class="p-10 bg-soft-bg rounded-2xl reveal hover:shadow-lg transition-shadow duration-300">
							<h3 class="text-xl font-medium mb-4 text-accent">{item.title}</h3>
							<p class="text-text-muted leading-relaxed">{item.text}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- About Mini Section -->
		<section class="section-padding bg-primary overflow-hidden">
			<div class="max-w-7xl mx-auto flex flex-col lg:flex-row items-center gap-16">
				<div class="lg:w-1/2 reveal">
					<h2 class="text-4xl md:text-5xl mb-8">Dra. Layla Sandes</h2>
					<p class="text-lg text-text-muted mb-6">
						Sou psicóloga e trabalho com a **Terapia Cognitivo-Comportamental (TCC)**. Meu foco é ajudar pessoas que lidam com ansiedade, dificuldade em se posicionar e o medo constante de desagradar os outros.
					</p>
					<p class="text-lg text-text-muted mb-8">
						Busco trazer a terapia de forma prática e aplicável ao seu dia a dia, ajudando você não só a compreender o que sente, mas também a desenvolver estratégias para lidar com os desafios de forma consciente.
					</p>
					<a href="/sobre" class="text-accent font-medium border-b-2 border-accent/20 pb-1 hover:border-accent transition-colors">
						Saiba mais sobre minha trajetória
					</a>
				</div>
				<div class="lg:w-1/2 reveal">
					<div class="border border-accent/20 p-2 relative">
						<img src="/images/layla/layla-sande-about.png" alt="Layla Sandes" class="w-full h-auto" />
					</div>
				</div>
			</div>
		</section>

		<!-- Services Section Preview -->
		<section class="section-padding bg-white">
			<div class="max-w-7xl mx-auto text-center mb-16 reveal">
				<h2 class="text-4xl md:text-5xl mb-6">Minhas Especialidades</h2>
				<p class="text-text-muted">Áreas onde posso te ajudar a encontrar equilíbrio e saúde.</p>
			</div>
			
			<div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
				{[
					{ title: 'Ansiedade', icon: '🍃' },
					{ title: 'Depressão', icon: '☀️' },
					{ title: 'Relacionamentos', icon: '🤝' },
					{ title: 'Autoconhecimento', icon: '✨' }
				].map(servico => (
					<div class="reveal border border-secondary/20 p-8 rounded-2xl hover:bg-soft-bg transition-colors duration-300">
						<div class="text-3xl mb-4">{servico.icon}</div>
						<h3 class="text-xl font-medium mb-4">{servico.title}</h3>
						<p class="text-sm text-text-muted mb-6">Abordagem terapêutica focada em resultados e bem-estar emocional.</p>
						<a href="/servicos" class="text-sm font-semibold text-accent uppercase tracking-wider">Ver detalhes</a>
					</div>
				))}
			</div>
		</section>

		<!-- CTA Banner -->
		<section class="section-padding">
			<div class="max-w-6xl mx-auto bg-secondary p-12 md:p-24 text-center text-primary reveal relative overflow-hidden">
				<div class="relative z-10">
					<h2 class="text-4xl md:text-7xl font-display text-white mb-8 leading-tight">Escolha investir <br class="hidden md:block"/> na sua saúde mental.</h2>
					<p class="text-lg opacity-90 mb-12 max-w-xl mx-auto font-sans">
						O primeiro passo é o mais importante, e você não precisa caminhar sozinha. Vamos conversar?
					</p>
					<a href="/contato" class="px-12 py-4 bg-accent text-white uppercase tracking-widest text-sm font-bold hover:bg-white hover:text-accent transition-all inline-block">
						Agende sua conversa agora
					</a>
				</div>
				<!-- Glow effects -->
				<div class="absolute -top-20 -right-20 w-80 h-80 bg-white/5 rounded-full blur-3xl"></div>
				<div class="absolute -bottom-20 -left-20 w-80 h-80 bg-accent/10 rounded-full blur-3xl"></div>
			</div>
		</section>
	</main>
	
	<Footer />
</Layout>
