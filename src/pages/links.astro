---
import Layout from '@/layouts/Layout.astro';
---

<Layout title="Links Importantes | Psicóloga Layla Sandes" description="Acompanhe o meu trabalho e agende sua consulta.">
	<main class="h-screen h-[100dvh] max-h-screen bg-[#FDFBFB] flex flex-col items-center justify-center px-6 py-4 md:py-8 overflow-hidden relative selection:bg-accent/20">
        <!-- Canvas for Particles -->
        <canvas id="particles-canvas" class="absolute inset-0 z-0 pointer-events-none opacity-40"></canvas>

        <!-- Background Elements (Subtle Gradient) -->
        <div class="absolute top-0 left-0 w-full h-full pointer-events-none opacity-[0.03]">
            <div class="absolute top-[-10%] left-[-10%] w-[50%] h-[50%] bg-accent rounded-full blur-[120px]"></div>
            <div class="absolute bottom-[-10%] right-[-10%] w-[50%] h-[50%] bg-secondary rounded-full blur-[120px]"></div>
        </div>
        
        <!-- Branding Area -->
        <div class="w-full max-w-[220px] md:max-w-[300px] mb-6 md:mb-10 text-center reveal opacity-0 flex flex-col items-center">
            <img 
                src="/images/logos/LS-logomarca-normal.png" 
                alt="Layla Sandes Psicologia" 
                class="w-full h-auto mx-auto"
            />
        </div>

        <!-- Links Container -->
        <div class="w-full max-w-[380px] space-y-3 md:space-y-4 relative z-10">

            <!-- Site Oficial -->
            <a 
                href="/" 
                class="link-card group flex items-center p-1 bg-white/40 backdrop-blur-sm border border-accent rounded-full hover:bg-accent/5 hover:scale-[1.02] active:scale-[0.98] transition-all duration-300 opacity-0"
            >
                <div class="w-10 h-10 md:w-12 md:h-12 flex items-center justify-center rounded-full border border-accent text-accent group-hover:bg-accent group-hover:text-white transition-all duration-500 ml-0.5">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="md:w-5 md:h-5"><circle cx="12" cy="12" r="10"/><line x1="2" x2="22" y1="12" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                </div>
                <div class="flex-1 text-center pr-10 md:pr-12">
                    <span class="text-secondary font-sans font-medium text-base md:text-lg tracking-wide">Site Oficial</span>
                </div>
            </a>

            <!-- WhatsApp -->
            <a 
                href="https://wa.me/5544991581606" 
                target="_blank" 
                class="link-card group flex items-center p-1 bg-white/40 backdrop-blur-sm border border-accent rounded-full hover:bg-accent/5 hover:scale-[1.02] active:scale-[0.98] transition-all duration-300 opacity-0"
            >
                <div class="w-10 h-10 md:w-12 md:h-12 flex items-center justify-center rounded-full border border-accent text-accent group-hover:bg-accent group-hover:text-white transition-all duration-500 ml-0.5">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="md:w-5 md:h-5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                </div>
                <div class="flex-1 text-center pr-10 md:pr-12">
                    <span class="text-secondary font-sans font-medium text-base md:text-lg tracking-wide">Whatsapp</span>
                </div>
            </a>

            <!-- Instagram -->
            <a 
                href="https://www.instagram.com/psi.laylasandes?igsh=MWs2cXo3c21tZ2xrdg%3D%3D" 
                target="_blank" 
                class="link-card group flex items-center p-1 bg-white/40 backdrop-blur-sm border border-accent rounded-full hover:bg-accent/5 hover:scale-[1.02] active:scale-[0.98] transition-all duration-300 opacity-0"
            >
                <div class="w-10 h-10 md:w-12 md:h-12 flex items-center justify-center rounded-full border border-accent text-accent group-hover:bg-accent group-hover:text-white transition-all duration-500 ml-0.5">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="md:w-5 md:h-5"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
                </div>
                <div class="flex-1 text-center pr-10 md:pr-12">
                    <span class="text-secondary font-sans font-medium text-base md:text-lg tracking-wide">Instagram</span>
                </div>
            </a>
                
            <!-- E-mail -->
            <a 
                href="mailto:layla.tamily@hotmail.com" 
                class="link-card group flex items-center p-1 bg-white/40 backdrop-blur-sm border border-accent rounded-full hover:bg-accent/5 hover:scale-[1.02] active:scale-[0.98] transition-all duration-300 opacity-0"
            >
                <div class="w-10 h-10 md:w-12 md:h-12 flex items-center justify-center rounded-full border border-accent text-accent group-hover:bg-accent group-hover:text-white transition-all duration-500 ml-0.5">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="md:w-5 md:h-5"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                </div>
                <div class="flex-1 text-center pr-10 md:pr-12">
                    <span class="text-secondary font-sans font-medium text-base md:text-lg tracking-wide">Email</span>
                </div>
            </a>
        </div>

        <!-- Branding Footer -->
        <div class="mt-6 md:mt-10 text-center opacity-0 branding-footer">
            <div class="space-y-1 md:space-y-2">
                <p class="text-[9px] uppercase tracking-[0.4em] text-accent font-bold">© 2026 Layla Sandes</p>
                <p class="text-[8px] uppercase tracking-[0.3em] text-accent/60">Desenvolvido por <a href="https://www.sitesalphacode.com.br/solucoes/psicologos" target="_blank" rel="noopener noreferrer" class="font-bold border-b border-accent/20 pb-0.5 hover:text-secondary transition-colors">Sites Alpha Code</a></p>
            </div>
        </div>
	</main>
</Layout>

<style>
    /* Prevent any vertical scroll */
    :global(html, body) {
        overflow: hidden !important;
        height: 100% !important;
    }

    /* Hide floating WA button on this page for a cleaner look as per the model */
    :global(.fixed.bottom-6.right-6) {
        display: none !important;
    }
</style>

<script>
    import gsap from 'gsap';

    function initParticles() {
        const canvas = document.getElementById('particles-canvas') as HTMLCanvasElement;
        if (!canvas) return;
        const ctx = canvas.getContext('2d');
        if (!ctx) return;

        let particles: Particle[] = [];
        const particleCount = 40;

        function resize() {
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
        }

        class Particle {
            x: number;
            y: number;
            size: number;
            speedX: number;
            speedY: number;
            opacity: number;

            constructor() {
                this.x = Math.random() * canvas.width;
                this.y = Math.random() * canvas.height;
                this.size = Math.random() * 2 + 0.5;
                this.speedX = (Math.random() - 0.5) * 0.4;
                this.speedY = (Math.random() - 0.5) * 0.4;
                this.opacity = Math.random() * 0.4 + 0.1;
            }

            update() {
                this.x += this.speedX;
                this.y += this.speedY;

                if (this.x > canvas.width) this.x = 0;
                if (this.x < 0) this.x = canvas.width;
                if (this.y > canvas.height) this.y = 0;
                if (this.y < 0) this.y = canvas.height;
            }

            draw() {
                if (!ctx) return;
                ctx.fillStyle = `rgba(122, 30, 30, ${this.opacity})`;
                ctx.beginPath();
                ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
                ctx.fill();
            }
        }

        function init() {
            particles = [];
            for (let i = 0; i < particleCount; i++) {
                particles.push(new Particle());
            }
        }

        function animate() {
            ctx!.clearRect(0, 0, canvas.width, canvas.height);
            particles.forEach(p => {
                p.update();
                p.draw();
            });
            requestAnimationFrame(animate);
        }

        window.addEventListener('resize', resize);
        resize();
        init();
        animate();
    }

    function initLinksAnimation() {
        const tl = gsap.timeline({ defaults: { ease: "power4.out" } });

        tl.to('.reveal', {
            opacity: 1,
            y: 0,
            duration: 1.2,
            startAt: { y: 20 }
        })
        .to('.link-card', {
            opacity: 1,
            y: 0,
            duration: 1,
            stagger: 0.12,
            startAt: { y: 30 }
        }, "-=0.8")
        .to('.branding-footer', {
            opacity: 1,
            duration: 1.5,
            y: 0,
            startAt: { y: 10 }
        }, "-=1");
    }

    // Initialize on load
    initParticles();
    initLinksAnimation();

    // Re-run on Astro navigation
    document.addEventListener('astro:after-swap', () => {
        initParticles();
        initLinksAnimation();
    });
</script>
