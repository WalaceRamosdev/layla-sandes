---
import Layout from '@/layouts/Layout.astro';
---

<Layout title="Links Importantes | Psicóloga Layla Sandes" description="Acompanhe o meu trabalho e agende sua consulta.">
	<main class="min-h-screen flex items-center justify-center py-8 px-4 overflow-hidden relative selection:bg-white/30 bg-[#FDFBFB]">
        <!-- Global Background Elements -->
        <div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] bg-secondary/5 rounded-full blur-[120px] animate-float"></div>
        <div class="absolute bottom-[-10%] right-[-10%] w-[40%] h-[40%] bg-accent/5 rounded-full blur-[120px] animate-float-delayed"></div>
        
        <!-- Main Content Card (Red Theme) -->
        <div class="w-full max-w-[420px] bg-secondary rounded-[3rem] shadow-[0_30px_100px_rgba(122,30,30,0.25)] relative z-10 py-12 px-8 flex flex-col items-center border border-white/10 h-fit overflow-hidden">
            
            <!-- Profile Area -->
            <div class="mb-10 text-center reveal opacity-0 profile-header">
                <div class="mb-6 relative inline-block group">
                    <!-- Outer decorative ring -->
                    <div class="absolute -inset-3 rounded-full border border-dashed border-white/20 group-hover:rotate-180 transition-transform duration-[3s] linear"></div>
                    
                    <div style="width: 100px; height: 100px;" class="rounded-full border-2 border-white/20 p-1 bg-white shadow-xl mx-auto relative z-10 transition-transform duration-500 group-hover:scale-105">
                        <img 
                            src="/images/logos/logo.svg" 
                            alt="Layla Sandes Logo" 
                            class="w-full h-full object-contain"
                        />
                    </div>
                </div>
                
                <div class="space-y-2">
                    <h1 class="text-xl font-display text-white uppercase tracking-[0.3em] font-bold">Layla Sandes</h1>
                    <div class="flex items-center justify-center space-x-3">
                        <span class="h-[1px] w-4 bg-white/30"></span>
                        <p class="text-[10px] text-white/90 uppercase tracking-[0.2em] font-semibold">Psicologia Clínica • CRP 08/47025</p>
                        <span class="h-[1px] w-4 bg-white/30"></span>
                    </div>
                </div>
            </div>

            <!-- Links Container -->
            <div class="w-full space-y-4">
                <a 
                    href="https://wa.me/5544991581606" 
                    target="_blank" 
                    class="link-card group flex items-center justify-between p-5 bg-white border border-transparent rounded-[2rem] shadow-lg hover:shadow-white/10 hover:scale-[1.03] transition-all duration-500 opacity-0"
                >
                    <div class="flex items-center space-x-4">
                        <div class="w-10 h-10 bg-secondary/10 rounded-full flex items-center justify-center text-secondary group-hover:bg-secondary group-hover:text-white transition-all duration-500 shadow-inner">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                        </div>
                        <div class="text-left">
                            <h3 class="text-[11px] font-bold text-secondary uppercase tracking-widest">Agendar Consulta</h3>
                            <p class="text-[9px] text-secondary/60 lowercase italic leading-none mt-1">Inicie seu processo hoje</p>
                        </div>
                    </div>
                    <div class="text-secondary/20 group-hover:translate-x-1 group-hover:text-secondary transition-all">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                    </div>
                </a>

                <a 
                    href="/" 
                    class="link-card group flex items-center justify-between p-5 bg-white border border-transparent rounded-[2rem] shadow-lg hover:shadow-white/10 hover:scale-[1.03] transition-all duration-500 opacity-0"
                >
                    <div class="flex items-center space-x-4">
                        <div class="w-10 h-10 bg-secondary/10 rounded-full flex items-center justify-center text-secondary group-hover:bg-secondary group-hover:text-white transition-all duration-500 shadow-inner">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" x2="22" y1="12" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                        </div>
                        <div class="text-left">
                            <h3 class="text-[11px] font-bold text-secondary uppercase tracking-widest">Site Oficial</h3>
                            <p class="text-[9px] text-secondary/60 lowercase italic leading-none mt-1">Explore nossa clínica</p>
                        </div>
                    </div>
                    <div class="text-secondary/20 group-hover:translate-x-1 group-hover:text-secondary transition-all">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                    </div>
                </a>

                <a 
                    href="/blog" 
                    class="link-card group flex items-center justify-between p-5 bg-white border border-transparent rounded-[2rem] shadow-lg hover:shadow-white/10 hover:scale-[1.03] transition-all duration-500 opacity-0"
                >
                    <div class="flex items-center space-x-4">
                        <div class="w-10 h-10 bg-secondary/10 rounded-full flex items-center justify-center text-secondary group-hover:bg-secondary group-hover:text-white transition-all duration-500 shadow-inner">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
                        </div>
                        <div class="text-left">
                            <h3 class="text-[11px] font-bold text-secondary uppercase tracking-widest">Blog & Conteúdo</h3>
                            <p class="text-[9px] text-secondary/60 lowercase italic leading-none mt-1">Autonomia emocional</p>
                        </div>
                    </div>
                    <div class="text-secondary/20 group-hover:translate-x-1 group-hover:text-secondary transition-all">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                    </div>
                </a>

                <a 
                    href="/#sobre" 
                    class="link-card group flex items-center justify-between p-5 bg-white border border-transparent rounded-[2rem] shadow-lg hover:shadow-white/10 hover:scale-[1.03] transition-all duration-500 opacity-0"
                >
                    <div class="flex items-center space-x-4">
                        <div class="w-10 h-10 bg-secondary/10 rounded-full flex items-center justify-center text-secondary group-hover:bg-secondary group-hover:text-white transition-all duration-500 shadow-inner">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                        </div>
                        <div class="text-left">
                            <h3 class="text-[11px] font-bold text-secondary uppercase tracking-widest">Sobre Mim</h3>
                            <p class="text-[9px] text-secondary/60 lowercase italic leading-none mt-1">Conheça minha jornada</p>
                        </div>
                    </div>
                    <div class="text-secondary/20 group-hover:translate-x-1 group-hover:text-secondary transition-all">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                    </div>
                </a>
            </div>

            <!-- Branding -->
            <div class="mt-auto pt-16 text-center opacity-0 branding-footer">
                <div class="relative group cursor-help inline-block mb-6">
                    <img src="/images/logos/sub-logo.svg" alt="LS Logo" style="width: 45px; height: auto;" class="mx-auto brightness-0 invert opacity-40 group-hover:opacity-100 transition-all duration-700 hover:rotate-[360deg]" />
                </div>
                
                <div class="space-y-1">
                    <p class="text-[8px] uppercase tracking-[0.4em] text-white/50 font-bold">© 2026 Layla Sandes</p>
                    <p class="text-[7px] uppercase tracking-[0.3em] text-white/30">Desenvolvido por <span class="font-bold border-b border-white/20 pb-0.5"><a href="https://www.sitesalphacode.com.br/solucoes/psicologos" target="_blank" rel="noopener noreferrer">Alpha Code</a></span></p>
                </div>
            </div>
        </div>
	</main>
</Layout>

<script>
    import gsap from 'gsap';

    function initLinksAnimation() {
        const tl = gsap.timeline({ defaults: { ease: "power4.out" } });

        tl.to('.profile-header', {
            opacity: 1,
            y: 0,
            duration: 1.2,
            startAt: { y: 20 }
        })
        .to('.link-card', {
            opacity: 1,
            y: 0,
            duration: 1,
            stagger: 0.12,
            startAt: { y: 30 }
        }, "-=1")
        .to('.branding-footer', {
            opacity: 1,
            duration: 1.5,
            y: 0,
            startAt: { y: 10 }
        }, "-=0.8");
    }

    initLinksAnimation();

    // Re-run on Astro navigation
    document.addEventListener('astro:after-swap', initLinksAnimation);
</script>

<style>
    main {
        position: relative;
	}
    
    .scrollbar-hide::-webkit-scrollbar {
        display: none;
    }
    .scrollbar-hide {
        -ms-overflow-style: none;
        scrollbar-width: none;
    }

    @keyframes float {
        0%, 100% { transform: translate(0, 0); }
        50% { transform: translate(30px, -30px); }
    }
    @keyframes float-delayed {
        0%, 100% { transform: translate(0, 0); }
        50% { transform: translate(-30px, 30px); }
    }
    .animate-float {
        animation: float 20s infinite ease-in-out;
    }
    .animate-float-delayed {
        animation: float-delayed 25s infinite ease-in-out;
    }
</style>
